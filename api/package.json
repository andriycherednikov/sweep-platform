{
  "name": "@sweep/api",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "node --env-file=../.env --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../.env src/db/migrate.js",
    "db:seed": "node --env-file=../.env src/seed/seed.js",
    "worker": "node --env-file=../.env src/worker.js",
    "sync": "node --env-file=../.env src/worker/run-baseline.js",
    "crosswalk:sync": "node --env-file=../.env src/worker/crosswalk-sync.js",
    "cutover": "node --env-file=../.env src/worker/cutover.js"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "drizzle-kit": "^0.28.1",
    "vitest": "^2.1.8"
  }
}
