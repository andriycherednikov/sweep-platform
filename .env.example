# Local dev uses the existing host Postgres (port 5432), dedicated `sweep` database.
# Copy to .env and set the real password (never commit it).
DATABASE_URL=postgres://localuser:YOUR_PASSWORD@localhost:5432/sweep
# If the api runs inside a container instead, reach the host DB via host.docker.internal:
#   DATABASE_URL=postgres://localuser:YOUR_PASSWORD@host.docker.internal:5432/sweep
PORT=3000
# Phase 2 — football worker (human provides the real key; never commit it)
API_FOOTBALL_KEY=your-api-football-pro-key
WC_SEASON=2026

# Phase 5 — photos + admin
# PHOTOS_DIR holds pending/ (api-only) + approved/ (served at /photos)
PHOTOS_DIR=./photos-data
# bcrypt hash of the admin passcode — generate with: npm run admin:hash -w api -- <passcode>
ADMIN_PASSCODE=
# secret that signs the admin session cookie (any long random string)
SESSION_SECRET=
# allowed browser origin in prod (Phase 6); unused in dev
SITE_ORIGIN=http://localhost:5173
