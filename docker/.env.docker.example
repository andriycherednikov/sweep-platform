# =============================================================================
# The Sweep — Production Runtime Environment
# =============================================================================
# Copy to `.env.docker` in this directory on the server and fill in real values.
# Read by docker compose at runtime for all containers (migrate, api, worker).
# NEVER commit the filled-in .env.docker (it is gitignored).
#
# Note: the web image needs NO env — the SPA uses relative API paths and the
# shared Caddy routes by path. There are no build-time public-URL args.
# =============================================================================

# --- Database (PostgreSQL) ---
# Shared simulation-postgres container on simulation-network. The `sweep`
# database must be created before first run (see README). Confirm the shared
# Postgres user/password on the server, then set them here.
DATABASE_URL=postgres://simulation:simulation@simulation-postgres:5432/sweep

# --- Server ---
NODE_ENV=production
PORT=3000
# World Cup season the worker syncs.
WC_SEASON=2026
# Photo storage root (persistent named volume). pending/ is api-only; approved/
# is what the api serves at /photos. Matches the volume mount in compose.
PHOTOS_DIR=/data/photos

# --- Secrets (fill these in) ---
# API-Football Pro key — the worker uses it; the SPA never calls the provider.
API_FOOTBALL_KEY=
# bcrypt HASH of the admin passcode. Generate with:
#   npm run admin:hash -w api -- <passcode>
# (or: docker compose run --rm api node src/seed/admin-hash.js <passcode>)
ADMIN_PASSCODE=
# Signs the admin session cookie. Generate with: openssl rand -base64 48
SESSION_SECRET=

# --- Origin ---
# Allowed browser origin. Same-origin behind Caddy today (currently inert in
# code), set for forward-compatibility.
SITE_ORIGIN=https://sweep.andriycherednikov.com
