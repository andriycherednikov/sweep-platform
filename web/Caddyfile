# Internal static server for the SPA (sits behind the shared vcv-caddy).
# Serves web/dist with client-side-routing history fallback + a /health probe.
:80 {
	encode gzip

	handle /health {
		respond "ok" 200
	}

	handle {
		root * /usr/share/caddy

		# Content-hashed bundles never change for a given URL → cache forever.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# The shell + service worker MUST always revalidate, so a deploy is
		# discovered immediately instead of being served from the HTTP cache.
		@shell not path /assets/*
		header @shell Cache-Control "no-cache"

		try_files {path} /index.html
		file_server
	}
}
